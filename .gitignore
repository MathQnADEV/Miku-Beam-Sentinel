# Reports & Scans
# Anchor to repo root so these only ignore generated report outputs — the previous
# unanchored *.html / *.json swallowed source files like web/frontend/index.html.
reports/
/report*.html
/report*.json
/scan_results*.json

# Temporary files
*.tmp
*.temp
.cache/
.pytest_cache/
