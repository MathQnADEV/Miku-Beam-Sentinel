# Copy this file to .env and fill in real values. NEVER commit the real .env.
#   cp web/backend/.env.example web/backend/.env

# Django secret key — generate a fresh, long, random value for each deployment.
# e.g. python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY='change-me-to-a-long-random-unguessable-value'

# Set to False in any shared/production environment.
DEBUG=True

# --- Database ---
# The default settings use SQLite for local development and need nothing here.
# The variables below are only read if you switch settings.py to MySQL/MariaDB.
DB_NAME='miku_beam_db'
DB_USER='root'
DB_PASSWORD=''
DB_HOST='localhost'
DB_PORT='3306'
